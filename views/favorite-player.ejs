<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Favorite Players</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css">

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="favorite-shell min-h-screen text-slate-100">

  <% const hasFavorites = favorites && favorites.length > 0; %>

  <section class="flex min-h-screen">

  <!-- Sidebar -->
  <%- include('partials/sidebar') %>

  <button id="menu-btn" class="md:hidden fixed left-4 top-4 z-50 rounded-2xl border border-white/10 bg-slate-950/90 p-3 text-white shadow-xl shadow-slate-950/30 backdrop-blur">
    <i class="fa-solid fa-bars"></i>
  </button>

  <main class="page-offset flex-1 px-4 pb-12 pt-20 md:px-8 md:pt-10">
    <div class="mx-auto flex w-full max-w-7xl flex-col gap-8">
      <section class="favorites-hero overflow-hidden rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-amber-950/15 backdrop-blur md:p-10">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(250,204,21,0.2),_transparent_26%),radial-gradient(circle_at_bottom_right,_rgba(56,189,248,0.14),_transparent_24%)]"></div>
        <div class="relative grid gap-8 xl:grid-cols-[1.2fr_0.9fr] xl:items-end">
          <div class="space-y-5">
            <span class="inline-flex items-center gap-2 rounded-full border border-amber-300/25 bg-amber-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em] text-amber-100">
              <i class="fa-solid fa-star"></i>
              Watchlist
            </span>

            <div class="space-y-3">
              <h1 class="text-4xl font-bold tracking-tight text-white md:text-6xl">Build a cleaner shortlist of players you want to track.</h1>
              <p class="max-w-2xl text-base leading-7 text-slate-300 md:text-lg">Search for players, save them to your personal watchlist, and jump into a focused profile view from one refreshed favorites hub.</p>
            </div>

            <form action="/favorite-player/searchPlayer" method="POST" class="flex flex-col gap-3 rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-3 sm:flex-row sm:items-center sm:p-4">
              <label for="favorite-player-search" class="sr-only">Search NBA player</label>
              <div class="flex flex-1 items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
                <input id="favorite-player-search" type="text" name="playerName" placeholder="Search NBA player" class="w-full border-0 bg-transparent p-0 text-base text-white placeholder:text-slate-500 focus:outline-none focus:ring-0" required>
              </div>
              <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-amber-400 px-5 py-3 font-semibold text-slate-950 transition hover:bg-amber-300">
                <span>Search</span>
                <i class="fa-solid fa-arrow-right"></i>
              </button>
            </form>
          </div>

          <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1 2xl:grid-cols-3">
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
              <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Favorites</p>
              <p class="mt-3 text-4xl font-bold text-white"><%= favorites ? favorites.length : 0 %></p>
              <p class="mt-2 text-sm text-slate-400">Players saved to your watchlist.</p>
            </article>
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
              <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Search State</p>
              <p class="mt-3 text-2xl font-bold text-white"><%= player ? 'Player loaded' : 'Ready' %></p>
              <p class="mt-2 text-sm text-slate-400"><%= player ? `${player.first_name} ${player.last_name} is ready for save/remove.` : 'Look up a player to add them quickly.' %></p>
            </article>
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
              <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Database</p>
              <p class="mt-3 text-2xl font-bold text-white"><%= error && error.includes('MongoDB') ? 'Offline' : 'Connected' %></p>
              <p class="mt-2 text-sm text-slate-400"><%= error && error.includes('MongoDB') ? 'Configure MongoDB to enable saved favorites.' : 'Favorites are available for this session.' %></p>
            </article>
          </div>
        </div>
      </section>

      <% if (error) { %>
        <div class="rounded-3xl border border-red-400/30 bg-red-500/10 px-5 py-4 text-red-100 shadow-lg shadow-red-950/20">
          <%= error %>
        </div>
      <% } %>

      <% if (player) { %>
        <% const isFav = favorites && favorites.some(f => f.playerId === player.id.toString()); %>
        <section class="favorite-search-result overflow-hidden rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/20 backdrop-blur md:p-8">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(250,204,21,0.14),_transparent_24%),radial-gradient(circle_at_bottom_left,_rgba(56,189,248,0.12),_transparent_22%)]"></div>
          <div class="relative grid gap-8 xl:grid-cols-[0.95fr_1.05fr] xl:items-start">
            <div class="space-y-5">
              <div class="flex items-center gap-4">
                <div class="flex h-24 w-24 items-center justify-center rounded-[2rem] bg-slate-950/70 text-3xl font-bold text-amber-100 shadow-xl shadow-amber-950/15">
                  <%= `${player.first_name.charAt(0)}${player.last_name.charAt(0)}` %>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.35em] text-amber-100">Search Result</p>
                  <h2 class="mt-2 text-4xl font-bold tracking-tight text-white"><%= player.first_name %> <%= player.last_name %></h2>
                  <p class="mt-2 text-base text-slate-300"><%= player.team.full_name %></p>
                </div>
              </div>

              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Position</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.position || 'N/A' %></p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Height</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.height_feet || 'N/A' %>' <%= player.height_inches || '' %>"</p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Weight</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.weight_pounds || 'N/A' %> lbs</p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Conference</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.team.conference %></p>
                </article>
              </div>
            </div>

            <div class="space-y-5">
              <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Division</p>
                <p class="mt-3 text-3xl font-bold text-white"><%= player.team.division %></p>
                <p class="mt-3 text-sm leading-6 text-slate-400">Save this player to your favorites if you want a quick route back to their detail profile.</p>
              </div>

              <form action="<%= isFav ? '/favorite-player/removeFavorite' : '/favorite-player/addFavorite' %>" method="POST" class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                <input type="hidden" name="playerId" value="<%= player.id %>">
                <input type="hidden" name="firstName" value="<%= player.first_name %>">
                <input type="hidden" name="lastName" value="<%= player.last_name %>">
                <input type="hidden" name="team" value="<%= player.team.full_name %>">
                <input type="hidden" name="position" value="<%= player.position %>">
                <input type="hidden" name="heightFeet" value="<%= player.height_feet %>">
                <input type="hidden" name="heightInches" value="<%= player.height_inches %>">
                <input type="hidden" name="weightPounds" value="<%= player.weight_pounds %>">

                <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl px-6 py-3 font-semibold transition <%= isFav ? 'bg-red-500 text-white hover:bg-red-400' : 'bg-amber-400 text-slate-950 hover:bg-amber-300' %>">
                  <i class="fa-solid <%= isFav ? 'fa-trash' : 'fa-star' %>"></i>
                  <span><%= isFav ? 'Remove from Favorites' : 'Add to Favorites' %></span>
                </button>
              </form>
            </div>
          </div>
        </section>
      <% } %>

      <section class="space-y-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-400">Your List</p>
            <h3 class="text-3xl font-bold text-white">Favorite players</h3>
          </div>
          <p class="text-sm text-slate-400">Open any card to view the full favorite profile.</p>
        </div>

        <% if (!hasFavorites) { %>
          <section class="rounded-[2rem] border border-dashed border-white/15 bg-white/5 px-6 py-16 text-center shadow-xl shadow-slate-950/30">
            <div class="mx-auto flex max-w-xl flex-col items-center gap-4">
              <span class="flex h-16 w-16 items-center justify-center rounded-full bg-amber-400/10 text-amber-100">
                <i class="fa-solid fa-star text-2xl"></i>
              </span>
              <h3 class="text-3xl font-bold text-white">No favorites yet</h3>
              <p class="text-base leading-7 text-slate-400">Search for a player above and save them to start building your watchlist.</p>
            </div>
          </section>
        <% } else { %>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
            <% favorites.forEach(fav => { %>
              <article class="favorite-card overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/8 p-6 shadow-xl shadow-slate-950/20 backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-amber-300/35">
                <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-300 via-yellow-400 to-cyan-400 opacity-80"></div>
                <div class="relative flex h-full flex-col gap-5">
                  <a href="/favorite-player/<%= fav.playerId %>" class="group flex flex-1 flex-col gap-5">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex items-center gap-4">
                        <div class="flex h-20 w-20 items-center justify-center rounded-3xl bg-slate-950/75 text-2xl font-bold text-amber-100 shadow-lg shadow-amber-950/15">
                          <%= `${fav.firstName.charAt(0)}${fav.lastName.charAt(0)}` %>
                        </div>
                        <div>
                          <p class="text-xs uppercase tracking-[0.3em] text-slate-500"><%= fav.position || 'N/A' %></p>
                          <h3 class="mt-2 text-2xl font-bold text-white"><%= fav.firstName %> <%= fav.lastName %></h3>
                          <p class="mt-2 text-sm text-slate-400"><%= fav.team %></p>
                        </div>
                      </div>

                      <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-slate-300 transition group-hover:bg-amber-400 group-hover:text-slate-950">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i>
                      </span>
                    </div>

                    <div class="grid grid-cols-2 gap-3 text-sm text-slate-300">
                      <div class="rounded-2xl border border-white/10 bg-slate-950/55 p-4">
                        <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Height</p>
                        <p class="mt-2 text-lg font-semibold text-white"><%= fav.heightFeet || 'N/A' %>' <%= fav.heightInches || '' %>"</p>
                      </div>
                      <div class="rounded-2xl border border-white/10 bg-slate-950/55 p-4">
                        <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Weight</p>
                        <p class="mt-2 text-lg font-semibold text-white"><%= fav.weightPounds || 'N/A' %> lbs</p>
                      </div>
                    </div>

                    <div class="mt-auto flex items-center justify-between border-t border-white/10 pt-4 text-sm text-slate-400">
                      <span>Open favorite profile</span>
                      <span class="font-semibold text-amber-100">View details</span>
                    </div>
                  </a>

                  <form action="/favorite-player/removeFavorite" method="POST">
                    <input type="hidden" name="playerId" value="<%= fav.playerId %>">
                    <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-red-500 px-4 py-3 font-semibold text-white transition hover:bg-red-400">
                      <i class="fa-solid fa-trash"></i>
                      <span>Remove</span>
                    </button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>
  </section>

  <script src="/js/main.js"></script>

</body>

</html>