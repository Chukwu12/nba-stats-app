<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
<title> Player Details</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="favorite-detail-shell min-h-screen text-slate-100">

  <div class="flex min-h-screen">
    <%- include('partials/sidebar') %>

    <button id="menu-btn" class="md:hidden fixed left-4 top-4 z-50 rounded-2xl border border-white/10 bg-slate-950/90 p-3 text-white shadow-xl shadow-slate-950/30 backdrop-blur">
      <i class="fa-solid fa-bars"></i>
    </button>

    <main class="page-offset flex-1 px-4 pb-12 pt-20 md:px-8 md:pt-10">
      <div class="mx-auto w-full max-w-7xl">

      <% if (player) { %>
        <section class="mb-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-amber-950/15 backdrop-blur md:p-8">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(250,204,21,0.16),_transparent_24%),radial-gradient(circle_at_bottom_right,_rgba(56,189,248,0.12),_transparent_22%)]"></div>
          <div class="relative flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div class="space-y-4">
              <a href="/favorite-player" class="inline-flex items-center gap-2 text-sm font-medium text-amber-100 transition hover:text-white">
                <i class="fa-solid fa-arrow-left"></i>
                Back to Favorites
              </a>

              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-amber-100">Favorite Profile</p>
                <h1 class="mt-3 text-4xl font-bold tracking-tight text-white md:text-6xl"><%= player.first_name %> <%= player.last_name %></h1>
                <p class="mt-3 text-base text-slate-300"><%= player.team?.full_name || player.team || 'N/A' %></p>
              </div>
            </div>

            <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-slate-950/55 px-4 py-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-amber-400/20 text-amber-100">
                <i class="fa-solid fa-star"></i>
              </span>
              <div>
                <p class="text-xs uppercase tracking-[0.28em] text-slate-500">Watchlist</p>
                <p class="mt-1 text-sm font-semibold text-white">Saved favorite</p>
              </div>
            </div>
          </div>
        </section>

        <section class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr] xl:items-start">
          <section class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-amber-950/15 backdrop-blur md:p-8">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(250,204,21,0.16),_transparent_24%),radial-gradient(circle_at_bottom_right,_rgba(56,189,248,0.12),_transparent_22%)]"></div>
            <div class="relative space-y-6">
              <div class="overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-slate-900 via-slate-800 to-amber-950 p-4">
                <img src="<%= image || '/img/default.jpeg' %>" alt="<%= player.first_name %> <%= player.last_name %>" class="h-80 w-full rounded-[1.25rem] object-cover object-top" onerror="this.onerror=null;this.src='/img/default.jpeg';">
              </div>

              <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1 2xl:grid-cols-3">
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Position</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.position || 'N/A' %></p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Height</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.height_feet || 'N/A' %>' <%= player.height_inches || '' %>"</p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Weight</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player.weight_pounds || 'N/A' %> lbs</p>
                </article>
              </div>
            </div>
          </section>

          <section class="space-y-6">
            <div class="space-y-4 rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-slate-950/20 backdrop-blur md:p-8">
              <div class="grid gap-4 md:grid-cols-2">
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Points</p>
                  <p class="mt-3 text-5xl font-bold text-white"><%= stats?.ppg || 'N/A' %></p>
                  <p class="mt-2 text-sm text-slate-400">Per-game scoring average.</p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Assists</p>
                  <p class="mt-3 text-5xl font-bold text-white"><%= stats?.apg || 'N/A' %></p>
                  <p class="mt-2 text-sm text-slate-400">Per-game assists average.</p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5 md:col-span-2">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Rebounds</p>
                  <p class="mt-3 text-5xl font-bold text-white"><%= stats?.rpg || 'N/A' %></p>
                  <p class="mt-2 text-sm text-slate-400">Per-game rebounding average.</p>
                </article>
              </div>
            </div>
          </section>
        </section>
      <% } else { %>
        <div class="mx-auto flex min-h-[70vh] max-w-xl items-center justify-center text-center">
          <div class="rounded-[2rem] border border-dashed border-white/15 bg-white/5 px-6 py-16 shadow-xl shadow-slate-950/30">
            <p class="text-2xl font-bold text-white">Player details not available.</p>
          </div>
        </div>
      <% } %>

      </div>
    </main>
  </div>

  <script src="/js/main.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const focusSection = document.querySelector('main section');
      if (focusSection) {
        focusSection.animate(
          [
            { opacity: 0, transform: 'translateY(24px)' },
            { opacity: 1, transform: 'translateY(0)' }
          ],
          {
            duration: 460,
            easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
            fill: 'both'
          }
        );
      }
    });
  </script>
</body>
</html>
