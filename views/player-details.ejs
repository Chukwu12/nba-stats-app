<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= player?.first_name || 'Player' %> <%= player?.last_name || '' %> | NBA Stats
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="players-shell bg-slate-950 text-slate-100">

  <% 
    const teamName = typeof player?.team === 'string'
      ? player.team
      : player?.team?.full_name || 'N/A';
    const playerName = `${player?.first_name || 'Player'} ${player?.last_name || ''}`.trim();
    const playerImage = image || '/img/default.jpeg';
  %>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar') %>

    <main class="player-page-main flex-1 px-4 pb-12 pt-20 md:px-8 md:pt-10">
      <div class="mx-auto flex w-full max-w-7xl flex-col gap-8">

      <% if (error) { %>
        <div class="rounded-3xl border border-red-400/30 bg-red-500/10 px-5 py-4 text-center text-red-100 shadow-lg shadow-red-950/20">
          <%= error %>
        </div>
      <% } %>

      <% if (player) { %>
        <section class="player-details-hero overflow-hidden rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-2xl shadow-cyan-950/25 backdrop-blur md:p-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(34,211,238,0.22),_transparent_25%),radial-gradient(circle_at_bottom_right,_rgba(249,115,22,0.16),_transparent_24%)]"></div>
          <div class="relative grid gap-8 xl:grid-cols-[0.85fr_1.15fr] xl:items-start">
            <div class="space-y-6">
              <div class="rounded-[1.75rem] border border-white/10 bg-slate-950/55 p-5 shadow-xl shadow-slate-950/20">
                <div class="overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950 p-4">
                  <img
                    src="<%= playerImage %>"
                    alt="<%= playerName %>"
                    class="player-detail-image h-80 w-full rounded-[1.25rem] object-cover object-top"
                    onerror="this.onerror=null;this.src='/img/default.jpeg';"
                  />
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1 2xl:grid-cols-3">
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Position</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player?.position || 'N/A' %></p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Team</p>
                  <p class="mt-3 text-xl font-bold text-white"><%= teamName %></p>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Jersey</p>
                  <p class="mt-3 text-2xl font-bold text-white">#<%= player?.jersey_number || 'N/A' %></p>
                </article>
              </div>
            </div>

            <div class="space-y-6">
              <div class="space-y-4">
                <a href="/players" class="inline-flex items-center gap-2 text-sm font-medium text-cyan-300 transition hover:text-cyan-200">
                  <i class="fa-solid fa-arrow-left"></i>
                  Back to Players
                </a>
                <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em] text-cyan-200">
                  <i class="fa-solid fa-chart-line"></i>
                  Player Profile
                </span>
                <div>
                  <h1 class="text-4xl font-bold tracking-tight text-white md:text-6xl"><%= playerName %></h1>
                  <p class="mt-3 max-w-2xl text-base leading-7 text-slate-300">A streamlined profile with player metadata, season averages, and quick actions for tracking favorites.</p>
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Height</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player?.height || 'N/A' %></p>
                </div>
                <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Weight</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player?.weight || 'N/A' %></p>
                </div>
                <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-5 md:col-span-2">
                  <p class="text-xs uppercase tracking-[0.3em] text-slate-500">College</p>
                  <p class="mt-3 text-2xl font-bold text-white"><%= player?.college || 'N/A' %></p>
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-4">
                <% if (!favorite) { %>
                  <form action="/favorite-player/addFavorite" method="POST">
                    <input type="hidden" name="playerId" value="<%= player?.id %>">
                    <input type="hidden" name="firstName" value="<%= player?.first_name %>">
                    <input type="hidden" name="lastName" value="<%= player?.last_name %>">
                    <input type="hidden" name="team" value="<%= teamName %>">
                    <button
                      type="submit"
                      class="inline-flex items-center gap-2 rounded-2xl bg-amber-400 px-6 py-3 font-semibold text-slate-950 transition hover:bg-amber-300"
                    >
                      <i class="fa-solid fa-star"></i>
                      Add to Favorites
                    </button>
                  </form>
                <% } else { %>
                  <p class="inline-flex items-center gap-2 rounded-2xl border border-emerald-400/25 bg-emerald-500/10 px-5 py-3 font-semibold text-emerald-200">
                    <i class="fa-solid fa-check"></i>
                    Already in Favorites
                  </p>
                <% } %>

                <% if (player?.links && player.links[0]) { %>
                  <a href="<%= player.links[0].href %>" target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-5 py-3 font-semibold text-slate-100 transition hover:border-cyan-400/30 hover:text-cyan-200">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    View on ESPN
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        </section>

        <section class="grid grid-cols-1 gap-4 md:grid-cols-3">
          <article class="rounded-[1.75rem] border border-cyan-400/20 bg-cyan-400/10 p-6 shadow-xl shadow-cyan-950/15">
            <p class="text-sm uppercase tracking-[0.3em] text-cyan-200">Points</p>
            <h3 class="mt-4 text-5xl font-bold text-white"><%= stats?.ppg || 'N/A' %></h3>
            <p class="mt-3 text-sm text-cyan-100/80">Average points per game.</p>
          </article>
          <article class="rounded-[1.75rem] border border-emerald-400/20 bg-emerald-400/10 p-6 shadow-xl shadow-emerald-950/15">
            <p class="text-sm uppercase tracking-[0.3em] text-emerald-200">Assists</p>
            <h3 class="mt-4 text-5xl font-bold text-white"><%= stats?.apg || 'N/A' %></h3>
            <p class="mt-3 text-sm text-emerald-100/80">Average assists per game.</p>
          </article>
          <article class="rounded-[1.75rem] border border-amber-400/20 bg-amber-400/10 p-6 shadow-xl shadow-amber-950/15">
            <p class="text-sm uppercase tracking-[0.3em] text-amber-200">Rebounds</p>
            <h3 class="mt-4 text-5xl font-bold text-white"><%= stats?.rpg || 'N/A' %></h3>
            <p class="mt-3 text-sm text-amber-100/80">Average rebounds per game.</p>
          </article>
        </section>
      <% } %>

      </div>
    </main>
  </div>

  <script>
    gsap.from(".player-details-hero", { opacity: 0, y: 28, duration: 0.8, ease: "power2.out" });
    gsap.from(".player-details-hero article, .player-details-hero form, .player-details-hero a, section article", {
      opacity: 0,
      y: 20,
      stagger: 0.08,
      duration: 0.45,
      delay: 0.18,
      ease: "power2.out"
    });
  </script>

</body>
</html>
